{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.studio/schemas/flow.schema.json",
  "type": "object",
  "required": ["id", "name", "trigger", "nodes", "edges", "isEnabled"],
  "properties": {
    "id": { "type": "string" },
    "workspaceId": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "trigger": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "config"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "label": { "type": "string" },
          "config": { "type": "object" },
          "position": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "condition": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "isEnabled": { "type": "boolean" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": false
}
