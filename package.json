{
  "name": "openclaw-dashboard",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for OpenClaw AI agents",
  "main": "dist/apps/api/src/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/apps/api/src/main.js",
    "dev": "NODE_ENV=development ts-node -P tsconfig.json apps/api/src/main.ts",
    "dev:legacy": "NODE_ENV=development node backend/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:profile-engine": "jest --selectProjects=profile-engine",
    "test:workspace-engine": "jest --selectProjects=workspace-engine",
    "test:api": "jest --selectProjects=api"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "agents",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ws": "^8.15.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
