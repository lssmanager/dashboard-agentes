{
  "name": "openclaw-dashboard",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for OpenClaw AI agents",
  "main": "dist/apps/api/src/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && npx vite build --config apps/web/vite.config.ts",
    "build:web": "npx vite build --config apps/web/vite.config.ts",
    "start": "node dist/apps/api/src/main.js",
    "dev": "NODE_ENV=development ts-node -P tsconfig.json apps/api/src/main.ts",
    "dev:web": "npx vite --config apps/web/vite.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:profile-engine": "jest --selectProjects=profile-engine",
    "test:workspace-engine": "jest --selectProjects=workspace-engine",
    "test:api": "jest --selectProjects=api"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "agents",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.0",
    "reactflow": "^11.11.0",
    "lucide-react": "^0.344.0",
    "ws": "^8.15.0",
    "zod": "^3.22.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "jest": "^29.5.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  }
}
